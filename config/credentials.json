{
  "schema_version": "1.0",
  "credentials": [
    {
      "name": "phase8-webhook-header",
      "type": "httpHeaderAuth",
      "secret_ref": "secret://n8n/phase8/webhook-header",
      "scope": "authenticated inbound Phase 8 webhooks"
    },
    {
      "name": "phase8-state-postgres",
      "type": "postgres",
      "secret_ref": "secret://n8n/phase8/postgres",
      "scope": "phase8 schema only"
    },
    {
      "name": "odoo-mcp-staging-bearer",
      "type": "httpBearerAuth",
      "secret_ref": "env://ODOO_MCP_STAGING_BEARER_TOKEN",
      "scope": "ocloud-staging draft-operations toolset"
    },
    {
      "name": "phase8-extractor-header",
      "type": "httpHeaderAuth",
      "secret_ref": "secret://n8n/phase8/extractor-header",
      "scope": "structured extraction endpoint; no training retention"
    },
    {
      "name": "phase8-artifact-store",
      "type": "s3",
      "secret_ref": "secret://n8n/phase8/artifact-store",
      "scope": "quarantine and controlled source artifacts"
    },
    {
      "name": "phase8-alert-webhook",
      "type": "httpHeaderAuth",
      "secret_ref": "secret://n8n/phase8/alert-webhook",
      "scope": "metadata-only operational alerts"
    },
    {
      "name": "phase8-delivery-header",
      "type": "httpHeaderAuth",
      "secret_ref": "secret://n8n/phase8/delivery-header",
      "scope": "allowlisted scheduled brief delivery endpoint"
    },
    {
      "name": "phase8-tax-rules-header",
      "type": "httpHeaderAuth",
      "secret_ref": "secret://n8n/phase8/tax-rules-header",
      "scope": "maintained Indonesian tax rule and calculation service"
    }
  ],
  "endpoints": [
    {
      "environment_variable": "ODOO_MCP_STAGING_URL",
      "config_ref": "config://n8n/endpoints/odoo-mcp-staging",
      "scope": "ocloud-staging MCP HTTP streamable endpoint"
    },
    {
      "environment_variable": "PHASE8_EXTRACTOR_URL",
      "config_ref": "config://n8n/endpoints/phase8-extractor",
      "scope": "structured extraction and matching service"
    },
    {
      "environment_variable": "PHASE8_TAX_RULES_URL",
      "config_ref": "config://n8n/endpoints/phase8-tax-rules",
      "scope": "versioned Indonesian tax calculation service"
    },
    {
      "environment_variable": "PHASE8_BRIEF_DELIVERY_URL",
      "config_ref": "config://n8n/endpoints/phase8-brief-delivery",
      "scope": "allowlisted scheduled brief destination"
    },
    {
      "environment_variable": "PHASE8_ALERT_URL",
      "config_ref": "config://n8n/endpoints/phase8-alert",
      "scope": "metadata-only operational alert destination"
    }
  ]
}
