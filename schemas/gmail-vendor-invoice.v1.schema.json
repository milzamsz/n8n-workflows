{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ocloud.example/schemas/phase8/gmail-vendor-invoice.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "source", "extraction", "resolution", "matching", "review"],
  "properties": {
    "envelope": { "$ref": "envelope.v1.schema.json" },
    "source": {
      "type": "object", "additionalProperties": false,
      "required": ["mailbox", "message_id", "sender", "filter_ref", "attachments"],
      "properties": {
        "mailbox": { "type": "string", "format": "email" },
        "message_id": { "type": "string", "minLength": 3, "maxLength": 512 },
        "sender": { "type": "string", "format": "email" },
        "filter_ref": { "const": "secret://n8n/gmail/vendor-invoice-filter" },
        "attachments": {
          "type": "array", "minItems": 1, "maxItems": 10,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["artifact_ref", "filename", "mime_type", "size_bytes", "content_hash", "malware_status"],
            "properties": {
              "artifact_ref": { "type": "string", "minLength": 3, "maxLength": 512 },
              "filename": { "type": "string", "minLength": 1, "maxLength": 255 },
              "mime_type": { "enum": ["application/pdf", "image/jpeg", "image/png"] },
              "size_bytes": { "type": "integer", "minimum": 1, "maximum": 20000000 },
              "content_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
              "malware_status": { "enum": ["clean", "quarantined", "scan_failed"] }
            }
          }
        }
      }
    },
    "extraction": {
      "type": "object", "additionalProperties": false,
      "required": ["vendor_name", "vendor_reference", "invoice_date", "due_date", "currency", "subtotal_minor", "tax_minor", "total_minor", "lines"],
      "properties": {
        "vendor_name": { "$ref": "#/$defs/field" },
        "vendor_reference": { "$ref": "#/$defs/field" },
        "invoice_date": { "$ref": "#/$defs/field" },
        "due_date": { "$ref": "#/$defs/field" },
        "currency": { "$ref": "#/$defs/field" },
        "subtotal_minor": { "$ref": "#/$defs/field" },
        "tax_minor": { "$ref": "#/$defs/field" },
        "total_minor": { "$ref": "#/$defs/field" },
        "lines": { "type": "array", "minItems": 1, "maxItems": 200, "items": { "$ref": "#/$defs/invoiceLine" } }
      }
    },
    "resolution": {
      "type": "object", "additionalProperties": false,
      "required": ["company_id", "vendor_id", "duplicate_vendor_reference"],
      "properties": {
        "company_id": { "const": 1 },
        "vendor_id": { "type": ["integer", "null"], "minimum": 1 },
        "duplicate_vendor_reference": { "type": "boolean" }
      }
    },
    "matching": {
      "type": "object", "additionalProperties": false,
      "required": ["purchase_orders", "receipts", "discrepancies"],
      "properties": {
        "purchase_orders": { "type": "array", "maxItems": 20, "items": { "type": "string", "maxLength": 100 } },
        "receipts": { "type": "array", "maxItems": 20, "items": { "type": "string", "maxLength": 100 } },
        "discrepancies": {
          "type": "array", "maxItems": 50,
          "items": { "enum": ["vendor_unresolved", "duplicate_reference", "no_po", "receipt", "product", "quantity", "price", "currency", "tax", "low_confidence"] }
        }
      }
    },
    "review": {
      "type": "object", "additionalProperties": false, "required": ["state", "owner", "posting_allowed"],
      "properties": {
        "state": { "enum": ["pending", "approved_for_draft", "rejected", "expired"] },
        "owner": { "const": "Accounts Payable Operations" },
        "posting_allowed": { "const": false }
      }
    }
  },
  "$defs": {
    "field": {
      "type": "object", "additionalProperties": false, "required": ["value", "confidence", "evidence_ref"],
      "properties": {
        "value": { "type": ["string", "integer", "null"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_ref": { "type": "string", "minLength": 3, "maxLength": 512 }
      }
    },
    "invoiceLine": {
      "type": "object", "additionalProperties": false,
      "required": ["description", "quantity_milli", "unit_price_minor", "tax_labels", "confidence", "evidence_ref"],
      "properties": {
        "description": { "type": "string", "minLength": 1, "maxLength": 500 },
        "quantity_milli": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "unit_price_minor": { "type": "integer", "minimum": 0, "maximum": 1000000000 },
        "tax_labels": { "type": "array", "maxItems": 10, "items": { "type": "string", "maxLength": 100 } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_ref": { "type": "string", "minLength": 3, "maxLength": 512 }
      }
    }
  }
}
