{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ocloud.example/schemas/phase8/linkedin-to-crm.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "source", "extraction", "duplicates", "review"],
  "properties": {
    "envelope": { "$ref": "envelope.v1.schema.json" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "captured_at", "capture_mechanism", "provenance"],
      "properties": {
        "url": { "type": "string", "format": "uri", "pattern": "^https://([a-z]+\\.)?linkedin\\.com/" },
        "captured_at": { "type": "string", "format": "date-time" },
        "capture_mechanism": { "enum": ["operator_url", "approved_export"] },
        "provenance": { "type": "string", "minLength": 3, "maxLength": 512 }
      }
    },
    "extraction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["organization", "person", "stated_need", "location", "facts", "inferences"],
      "properties": {
        "organization": { "$ref": "#/$defs/evidencedNullableString" },
        "person": { "$ref": "#/$defs/evidencedNullableString" },
        "stated_need": { "$ref": "#/$defs/evidencedNullableString" },
        "location": { "$ref": "#/$defs/evidencedNullableString" },
        "facts": { "type": "array", "maxItems": 50, "items": { "$ref": "#/$defs/evidencedClaim" } },
        "inferences": { "type": "array", "maxItems": 20, "items": { "$ref": "#/$defs/evidencedClaim" } }
      }
    },
    "duplicates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["partner_candidates", "lead_candidates", "match_explanation"],
      "properties": {
        "partner_candidates": { "$ref": "#/$defs/candidates" },
        "lead_candidates": { "$ref": "#/$defs/candidates" },
        "match_explanation": { "type": "string", "minLength": 3, "maxLength": 1000 }
      }
    },
    "review": { "$ref": "#/$defs/review" }
  },
  "$defs": {
    "evidencedNullableString": {
      "type": "object", "additionalProperties": false, "required": ["value", "confidence", "evidence_refs"],
      "properties": {
        "value": { "type": ["string", "null"], "maxLength": 500 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_refs": { "type": "array", "maxItems": 10, "items": { "type": "string", "maxLength": 512 } }
      }
    },
    "evidencedClaim": {
      "type": "object", "additionalProperties": false, "required": ["claim", "confidence", "evidence_refs"],
      "properties": {
        "claim": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_refs": { "type": "array", "minItems": 1, "maxItems": 10, "items": { "type": "string", "maxLength": 512 } }
      }
    },
    "candidates": {
      "type": "array", "maxItems": 20,
      "items": {
        "type": "object", "additionalProperties": false, "required": ["id", "confidence", "explanation"],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "explanation": { "type": "string", "minLength": 3, "maxLength": 500 }
        }
      }
    },
    "review": {
      "type": "object", "additionalProperties": false, "required": ["state", "owner", "proposed_title", "proposed_description"],
      "properties": {
        "state": { "enum": ["pending", "approved", "rejected", "expired"] },
        "owner": { "const": "CRM Operations" },
        "proposed_title": { "type": "string", "minLength": 3, "maxLength": 200 },
        "proposed_description": { "type": "string", "minLength": 3, "maxLength": 4000 }
      }
    }
  }
}
